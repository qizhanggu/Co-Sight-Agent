# ===== 閫氱敤閰嶇疆 =====
ENVIRONMENT=development

# ===== 鎬ラ€熸ā寮忛厤缃?=====
# 鍚敤鎬ラ€熸ā寮忓彲浠ュ噺灏戣鍒掓楠ゃ€佸噺灏戝伐鍏疯皟鐢ㄦ鏁般€佸噺灏戜腑闂存枃浠剁敓鎴?# 璁剧疆涓?True 鎴?1 鍚敤鎬ラ€熸ā寮忥紝False 鎴?0 绂佺敤
TURBO_MODE=False

# ===== 涓婁笅鏂囩鐞嗛厤缃?=====
# 鏄惁鍚敤鏅鸿兘涓婁笅鏂囧帇缂╋紙鎺ㄨ崘鍚敤锛?ENABLE_CONTEXT_COMPRESSION=false
# LLM鐨勬渶澶т笂涓嬫枃闀垮害锛坱okens锛夛紝鏍规嵁妯″瀷璋冩暣
MAX_CONTEXT_TOKENS=128000
# 鍘嬬缉瑙﹀彂闃堝€硷紙0-1涔嬮棿锛夛紝杈惧埌姝ゆ瘮渚嬫椂瑙﹀彂鍘嬬缉
COMPRESSION_THRESHOLD=0.8
# 淇濈暀鏈€鍒濆嚑杞璇濅笉鍘嬬缉锛堥€氬父鍖呭惈浠诲姟鐩爣锛?KEEP_INITIAL_TURNS=2
# 淇濈暀鏈€杩戝嚑杞璇濅笉鍘嬬缉锛堜繚鎸佷笂涓嬫枃杩炶疮锛?KEEP_RECENT_TURNS=3

# 娑堟伅鎴柇閰嶇疆锛堜綔涓轰笂涓嬫枃绠＄悊鐨勫悗澶囷級
MAX_MESSAGES=30
MAX_TOOL_CONTENT_LENGTH=50000

# ===== LLM杩炴帴瓒呮椂閰嶇疆 =====
# LLM璇诲彇瓒呮椂鏃堕棿锛堢锛夛紝閫傜敤浜庢墍鏈塋LM璋冪敤
LLM_TIMEOUT=60

